---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Insights — Varun Vashisht"
  description="Short reads on PMO, digital transformation, and AI in enterprise delivery by Varun Vashisht."
>

  <header class="nav">
    <div class="nav-inner container">
      <a class="brand" href="/varun-portfolio2/" aria-label="Varun Vashisht — home">
        <span class="brand-mark">VV</span>
        <span class="brand-text">Varun Vashisht</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="/varun-portfolio2/#about">About</a>
        <a href="/varun-portfolio2/#experience">Experience</a>
        <a href="/varun-portfolio2/#skills">Skills</a>
        <a href="/varun-portfolio2/#cases">Case Studies</a>
        <a href="/varun-portfolio2/#insights">Insights</a>
        <a href="/varun-portfolio2/#contact" class="nav-cta">Contact</a>
      </nav>
      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main class="blog-listing-page">
    <div class="container">
      <div class="blog-listing-header">
        <p class="eyebrow">Insights</p>
        <h1>Notes from the field</h1>
        <p class="section-sub">Short reads on PMO, transformation, and AI in enterprise delivery.</p>
      </div>

      {posts.length === 0 ? (
        <p style="color: var(--text-mute); text-align: center; padding: 60px 0;">No posts published yet. Check back soon.</p>
      ) : (
        <div class="insights-grid">
          {posts.map(post => {
            const pubDateFormatted = new Intl.DateTimeFormat('en-GB', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            }).format(post.data.pubDate);
            return (
              <article class="post" data-reveal>
                {post.data.heroImage && (
                  <a href={`/varun-portfolio2/blog/${post.id}`} class="post-img" aria-label={`Read post: ${post.data.title}`}>
                    <img src={post.data.heroImage} alt={post.data.title} loading="lazy" width="1100" height="688" />
                  </a>
                )}
                <div class="post-body">
                  {post.data.tags && post.data.tags[0] && (
                    <span class="post-tag">{post.data.tags[0]}</span>
                  )}
                  <h2 class="post-h2"><a href={`/varun-portfolio2/blog/${post.id}`}>{post.data.title}</a></h2>
                  <p>{post.data.description}</p>
                  <span class="post-meta">{pubDateFormatted}</span>
                </div>
              </article>
            );
          })}
        </div>
      )}

      <div style="margin-top: 64px;">
        <a href="/varun-portfolio2/" class="btn btn-ghost-blog">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Back to portfolio
        </a>
      </div>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div>&copy; <span id="year"></span> Varun Vashisht. All rights reserved.</div>
      <div class="footer-links">
        <a href="/varun-portfolio2/#about">About</a>
        <a href="/varun-portfolio2/#cases">Case Studies</a>
        <a href="/varun-portfolio2/#contact">Contact</a>
      </div>
    </div>
  </footer>

  <script is:inline src="/varun-portfolio2/assets/js/main.js"></script>

</Layout>
