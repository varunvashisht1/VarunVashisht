---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const galleryItems = (await getCollection('gallery')).sort((a, b) => a.data.order - b.data.order);
const caseStudies = (await getCollection('cases')).sort((a, b) => a.data.order - b.data.order);
const certifications = (await getCollection('certifications')).sort((a, b) => a.data.order - b.data.order);
const experiences = (await getCollection('experience')).sort((a, b) => {
  if (a.data.current && !b.data.current) return -1;
  if (!a.data.current && b.data.current) return 1;
  return a.data.order - b.data.order;
});

const base = '';
---

<Layout>

  <header class="nav">
    <div class="nav-inner container">
      <a class="brand" href="#hero" aria-label="Varun Vashisht — home">
        <span class="brand-mark">VV</span>
        <span class="brand-text">Varun Vashisht</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#about">About</a>
        <a href="#experience">Experience</a>
        <a href="#skills">Skills</a>
        <a href="#methodology">Methodology</a>
        <a href="#cases">Case Studies</a>
        <a href="#gallery">Gallery</a>
        <a href="#certifications">Certifications</a>
        <a href="#insights">Insights</a>
        <a href="#contact" class="nav-cta">Contact</a>
      </nav>
      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <section id="hero" class="hero">
    <div class="hero-media" aria-hidden="true">
      <img class="hero-img"
           src={`${base}/media/hero-office-empty.png`}
           onerror="this.onerror=null;this.src='/media/hero-bg.jpg';"
           alt="Hero Background" />
      <div class="hero-overlay"></div>
      <img class="hero-person"
           src={`${base}/media/hero-person.png`}
           alt="Varun Vashisht" />
    </div>

    <div class="hero-content container">
      <p class="eyebrow on-dark">Senior Program Manager  ·  TPM  ·  Business Architect</p>
      <h1 class="hero-title">
        Delivering enterprise transformation with measurable outcomes.
      </h1>
      <p class="hero-sub">
        14+ years building PMOs, leading SDLC rollouts, and embedding generative AI into the way enterprise programs are run — across Healthcare, Oil &amp; Energy, Fintech, and Telecom.
      </p>
      <div class="hero-cta">
        <a href="#cases" class="btn btn-primary">
          <span>Explore case studies</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#contact" class="btn btn-ghost-light">Get in touch</a>
      </div>
      <ul class="hero-meta">
        <li><span>14+</span><em>Years</em></li>
        <li><span>$8M</span><em>Program budget</em></li>
        <li><span>20+</span><em>Cross-functional team</em></li>
        <li><span>PMP · CBAP · PMI-PBA</span><em>Certifications</em></li>
      </ul>
    </div>
  </section>

  <section id="about" class="section about" data-reveal>
    <div class="container about-grid">
      <div class="about-visual">
        <div class="about-photo">
          <img src={`${base}/media/about.jpg`}
               onerror="this.onerror=null;this.src='/media/avatar.png';"
               alt="Varun Vashisht"
               loading="lazy" width="480" height="600" />
        </div>
        <div class="about-card">
          <span class="about-card-label">Currently</span>
          <strong>Senior Program Manager</strong>
          <em>Blue Ocean Corporation</em>
        </div>
      </div>
      <div class="about-text">
        <p class="eyebrow">About</p>
        <h2>A trusted partner for engineering, product, and C-level leadership.</h2>
        <p>
          I lead enterprise digital transformation programs end-to-end &mdash; from PMO setup and business architecture through delivery and adoption. I&rsquo;ve owned program budgets up to <strong>$8M</strong>, globally distributed teams of <strong>20+</strong>, and full SDLC rollouts on Microsoft Dynamics 365, Zoho One, Ramco HCM, Azure, and Power BI.
        </p>
        <p>
          As a TCS Certified GenAI Practitioner, I embed prompt engineering and AI/ML proofs of concept into requirements, reporting, and resource workflows &mdash; so program teams move faster with sharper signal.
        </p>
        <ul class="about-bullets">
          <li>Agile (Scrum, Kanban, SAFe), Waterfall, and Hybrid delivery.</li>
          <li>SQL, Python, SSIS ETL, REST APIs, and Azure DevOps.</li>
          <li>Power BI, Tableau, Zoho Analytics, and KPI dashboards.</li>
          <li>Vendor &amp; partner ecosystem governance, RFP / RFI, business case &amp; ROI.</li>
        </ul>
      </div>
    </div>
  </section>

  <section id="stats" class="section stats" data-reveal>
    <div class="container">
      <ul class="stats-grid">
        <li class="stat"><div class="stat-num"><span class="counter" data-target="14">0</span><sup>+</sup></div><div class="stat-label">Years driving enterprise delivery</div></li>
        <li class="stat"><div class="stat-num">$<span class="counter" data-target="8">0</span><sup>M</sup></div><div class="stat-label">Program budget under direct ownership</div></li>
        <li class="stat"><div class="stat-num"><span class="counter" data-target="20">0</span><sup>+</sup></div><div class="stat-label">Cross-functional global team members</div></li>
        <li class="stat"><div class="stat-num"><span class="counter" data-target="80">0</span><sup>%</sup></div><div class="stat-label">Faster project-to-resource matching via AI/ML PoC</div><small class="stat-source">Python ML pilot · TCS, 2024</small></li>
        <li class="stat"><div class="stat-num"><span class="counter" data-target="50">0</span><sup>%</sup></div><div class="stat-label">Reduction in manual QA via SSIS automation</div><small class="stat-source">ETL test framework · Birlasoft, 2021–22</small></li>
        <li class="stat"><div class="stat-num"><span class="counter" data-target="99">0</span><sup>.9%</sup></div><div class="stat-label">System continuity across global sites</div><small class="stat-source">$8M security portfolio · TCS, 2022–26</small></li>
      </ul>
    </div>
  </section>

  <section id="experience" class="section experience" data-reveal>
    <div class="container">
      <p class="eyebrow center">Career</p>
      <h2 class="section-title center">Experience</h2>
      <p class="section-sub center">Fourteen years across digital transformation, PMO setup, and platform delivery.</p>

      <div class="timeline">
        <div class="tl-line"></div>

        {experiences.map(exp => (
          <article class="tl-item" data-reveal>
            <div class="tl-dot"></div>
            <div class="tl-card">
              <div class="tl-head">
                <h3>{exp.data.title}</h3>
                <span class="tl-org">{exp.data.company}</span>
                <span class="tl-date">{exp.data.startDate} – {exp.data.endDate}</span>
              </div>
              <p>{exp.data.description}</p>
              {exp.data.bullets && exp.data.bullets.length > 0 && (
                <ul>
                  {exp.data.bullets.map(bullet => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="skills" class="section skills" data-reveal>
    <div class="container">
      <p class="eyebrow center">Capabilities</p>
      <h2 class="section-title center">Skills &amp; Stack</h2>
      <p class="section-sub center">Hands-on across delivery methodologies, data, cloud, and AI tooling.</p>

      <div class="skills-grid">
        <div class="skill-card" data-reveal>
          <h3>Program &amp; Delivery</h3>
          <div class="chips"><span>Program Management</span><span>TPM</span><span>PMO Setup</span><span>Portfolio</span><span>Agile / Scrum</span><span>Kanban</span><span>SAFe</span><span>Waterfall</span><span>Hybrid</span><span>RAID</span><span>OKRs &amp; KPIs</span></div>
        </div>
        <div class="skill-card" data-reveal>
          <h3>Business Architecture &amp; BA</h3>
          <div class="chips"><span>BRD / FRD / SRS</span><span>HLD / LLD</span><span>User Stories</span><span>BPMN</span><span>Gap &amp; Impact Analysis</span><span>RFP / RFI</span><span>ROI &amp; Business Case</span><span>Lucidchart</span><span>Visio</span><span>Miro</span><span>Figma</span></div>
        </div>
        <div class="skill-card" data-reveal>
          <h3>Platforms &amp; ERP/CRM</h3>
          <div class="chips"><span>Microsoft Dynamics 365</span><span>Zoho One</span><span>Zoho CRM</span><span>Zoho Books / Projects / Analytics</span><span>Zoho Creator</span><span>Ramco HCM</span><span>Salesforce</span><span>SAP</span><span>Workday</span><span>Genetec</span><span>Honeywell Pro-Watch</span></div>
        </div>
        <div class="skill-card" data-reveal>
          <h3>Data, BI &amp; Analytics</h3>
          <div class="chips"><span>SQL / T-SQL</span><span>Stored Procedures</span><span>SSIS ETL</span><span>Snowflake</span><span>DBT</span><span>Alteryx</span><span>Power BI</span><span>Tableau</span><span>Zoho Analytics</span><span>Excel (Advanced)</span><span>KPI Dashboards</span></div>
        </div>
        <div class="skill-card" data-reveal>
          <h3>Cloud, Integration &amp; Code</h3>
          <div class="chips"><span>Microsoft Azure</span><span>Azure DevOps</span><span>Azure OpenAI</span><span>REST APIs</span><span>Webhooks</span><span>Python</span><span>C</span><span>SharePoint</span><span>Power Automate</span><span>Power Apps</span><span>Git</span></div>
        </div>
        <div class="skill-card highlight" data-reveal>
          <h3>Generative AI</h3>
          <div class="chips"><span>GenAI Strategy</span><span>Prompt Engineering</span><span>LLM Applications</span><span>Microsoft Copilot</span><span>Azure OpenAI</span><span>AI-Assisted Reporting</span><span>AI/ML PoC (Python)</span><span>Conversational / Recommendation AI</span></div>
        </div>
      </div>
    </div>
  </section>

  <section id="methodology" class="section methodology" data-reveal>
    <div class="container">
      <p class="eyebrow center">Framework</p>
      <h2 class="section-title center">Methodology</h2>
      <p class="section-sub center">A structured approach to delivery, blending agile rhythm with enterprise rigour.</p>

      <div class="methodology-grid">
        <div class="method-step" data-reveal>
          <span class="step-num">01</span>
          <h3>Discovery &amp; Strategy</h3>
          <p>Aligning stakeholder vision, understanding current-state constraints, and defining measurable KPIs and target architecture.</p>
        </div>
        <div class="method-step" data-reveal>
          <span class="step-num">02</span>
          <h3>Architecture &amp; Design</h3>
          <p>Drafting HLD/LLD, selecting right-fit vendors, and mapping complex enterprise integrations securely.</p>
        </div>
        <div class="method-step" data-reveal>
          <span class="step-num">03</span>
          <h3>Agile Execution</h3>
          <p>Managing backlogs, orchestrating global cross-functional teams, and running data-driven PMO cadences.</p>
        </div>
        <div class="method-step" data-reveal>
          <span class="step-num">04</span>
          <h3>Adoption &amp; Handover</h3>
          <p>Ensuring 95%+ user adoption through training, robust documentation, and ongoing AI-assisted governance.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="cases" class="section cases" data-reveal>
    <div class="container">
      <p class="eyebrow center">Selected Work</p>
      <h2 class="section-title center">Case Studies</h2>
      <p class="section-sub center">Three programmes that highlight strategy, delivery rigour, and AI-enabled execution.</p>

      <div class="cases-grid">
        {caseStudies.map(cs => (
          <article class="case" data-reveal>
            <div class="case-img">
              <img src={`${base}${cs.data.image}`}
                   onerror={`this.onerror=null;this.src='${cs.data.imageFallback || cs.data.image}';`}
                   alt={cs.data.imageAlt}
                   loading="lazy" width="800" height="500" />
              <span class="case-tag">{cs.data.tag}</span>
            </div>
            <div class="case-body">
              <h3>{cs.data.title}</h3>
              <p>{cs.data.description}</p>
              <div class="case-meta">
                {cs.data.meta.map(m => <span>{m}</span>)}
              </div>
              <div class="case-result" set:html={cs.data.result}></div>
              <button class="btn-case-detail" data-open-modal={`case-modal-${cs.id}`} aria-haspopup="dialog">View full case study →</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="certifications" class="section certs" data-reveal>
    <div class="container">
      <p class="eyebrow center">Credentials</p>
      <h2 class="section-title center">Certifications</h2>
      <p class="section-sub center">Active credentials across program management, business analysis, and cloud.</p>

      <div class="certs-grid">
        {certifications.map(cert => (
          <div class="cert" data-reveal>
            <div class="cert-mark">{cert.data.mark}</div>
            <div>
              <h4>{cert.data.title}</h4>
              <span>{cert.data.issuer}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="gallery" class="section gallery" data-reveal>
    <div class="container">
      <p class="eyebrow center">Moments</p>
      <h2 class="section-title center">Gallery</h2>
      <p class="section-sub center">A glimpse into my professional journey, speaking engagements, and team collaborations.</p>

      <div class="gallery-grid">
        {galleryItems.map(item => (
          <div class="gallery-item" data-reveal>
            <img src={`${base}${item.data.image}`} alt={item.data.alt} loading="lazy" width="600" height="600" />
            <div class="gallery-caption">{item.data.caption}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="insights" class="section insights" data-reveal>
    <div class="container">
      <p class="eyebrow center">Insights</p>
      <h2 class="section-title center">Notes from the field</h2>
      {publishedPosts.length > 0 ? (
        <p class="section-sub center">Short reads on PMO, transformation, and AI in delivery.</p>
      ) : (
        <p class="section-sub center">Short reads on PMO, transformation, and AI in delivery &mdash; coming soon.</p>
      )}

      <div class="insights-grid">
        {publishedPosts.length > 0 ? (
          publishedPosts.map(post => (
            <article class="post" data-reveal>
              {post.data.heroImage && (
                <a href={`${base}/blog/${post.id}`} class="post-img" aria-label={`Read post: ${post.data.title}`}>
                  <img src={post.data.heroImage} alt={post.data.title} loading="lazy" width="1100" height="688" />
                </a>
              )}
              <div class="post-body">
                {post.data.tags && post.data.tags[0] && (
                  <span class="post-tag">{post.data.tags[0]}</span>
                )}
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <a href={`${base}/blog/${post.id}`} class="post-meta">Read post →</a>
              </div>
            </article>
          ))
        ) : (
          <>
            <article class="post" data-reveal>
              <a href="#" class="post-img" aria-label="Read post: Building a PMO that engineering actually wants to work with"><img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=1100&q=80&auto=format&fit=crop" onerror="this.onerror=null;this.src='/media/blog-1.jpg';" alt="Team collaborating around a table in a modern office" loading="lazy" width="1100" height="688" /></a>
              <div class="post-body">
                <span class="post-tag">PMO</span>
                <h3>Building a PMO that engineering actually wants to work with</h3>
                <p>Cadences, RAID hygiene, and the rituals that turn governance into a velocity engine.</p>
                <span class="post-meta">Coming soon · 7 min read</span>
              </div>
            </article>
            <article class="post" data-reveal>
              <a href="#" class="post-img" aria-label="Read post: Where Generative AI quietly pays off inside a PMO"><img src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=1100&q=80&auto=format&fit=crop" onerror="this.onerror=null;this.src='/media/blog-2.jpg';" alt="Abstract visualization of artificial intelligence neural networks" loading="lazy" width="1100" height="688" /></a>
              <div class="post-body">
                <span class="post-tag">GenAI</span>
                <h3>Where Generative AI quietly pays off inside a PMO</h3>
                <p>Requirements drafting, status synthesis, RAID summaries &mdash; the unglamorous wins.</p>
                <span class="post-meta">Coming soon · 6 min read</span>
              </div>
            </article>
            <article class="post" data-reveal>
              <a href="#" class="post-img" aria-label="Read post: Choosing a VMS without falling for the demo"><img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=1100&q=80&auto=format&fit=crop" onerror="this.onerror=null;this.src='/media/blog-3.jpg';" alt="Person reviewing documents and contracts at a desk" loading="lazy" width="1100" height="688" /></a>
              <div class="post-body">
                <span class="post-tag">Vendor Strategy</span>
                <h3>Choosing a VMS without falling for the demo</h3>
                <p>A simple framework for evaluating enterprise platforms beyond the sales theatre.</p>
                <span class="post-meta">Coming soon · 8 min read</span>
              </div>
            </article>
          </>
        )}
      </div>
    </div>
  </section>

  <section id="contact" class="section contact" data-reveal>
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Contact</p>
        <h2 class="section-title">Let&rsquo;s build something measurable.</h2>
        <p class="section-sub">Open to senior PMO, TPM, and digital transformation roles &mdash; full-time, advisory, or fractional.</p>

        <ul class="contact-list">
          <li><span class="ci">@</span><a href="mailto:varun.vashisht@live.com">varun.vashisht@live.com</a></li>
          <li><span class="ci">☏</span><a href="tel:+918800426407">+91-8800426407</a></li>
          <li><span class="ci">in</span><a href="https://linkedin.com/in/varunvashisht1" target="_blank" rel="noopener">linkedin.com/in/varunvashisht1</a></li>
          <li><span class="ci">◉</span><span>Faridabad, Delhi NCR &mdash; 121004</span></li>
        </ul>
      </div>

      <form class="contact-form" onsubmit="return handleContact(event)">
        <div class="field"><label for="cname">Your name</label><input id="cname" name="name" type="text" required autocomplete="name" /></div>
        <div class="field"><label for="cemail">Email</label><input id="cemail" name="email" type="email" required autocomplete="email" /></div>
        <div class="field"><label for="cmsg">Message</label><textarea id="cmsg" name="message" rows="5" required></textarea></div>
        <button type="submit" class="btn btn-primary full">
          <span>Send message</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <p class="form-note" id="form-note" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-inner">
      <div>&copy; <span id="year"></span> Varun Vashisht. All rights reserved.</div>
      <div class="footer-links"><a href="#about">About</a><a href="#cases">Case Studies</a><a href="#contact">Contact</a></div>
    </div>
  </footer>

  <!-- Case Study Modals (dynamic) -->
  {caseStudies.map(cs => (
    <div class="modal" id={`case-modal-${cs.id}`} role="dialog" aria-modal="true" aria-labelledby={`cm-${cs.id}-title`} hidden>
      <div class="modal-overlay" data-modal-close></div>
      <div class="modal-box">
        <button class="modal-close" aria-label="Close case study" data-modal-close>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="modal-content">
          <span class="case-tag" style="position:static;margin-bottom:16px;display:inline-block;">{cs.data.tag}</span>
          <h2 id={`cm-${cs.id}-title`}>{cs.data.title}</h2>
          <div class="modal-meta">
            {cs.data.modalMeta.map(m => <span>{m}</span>)}
          </div>
          <div class="modal-section">
            <h4>Challenge</h4>
            <p>{cs.data.challenge}</p>
          </div>
          <div class="modal-section">
            <h4>Approach</h4>
            <p>{cs.data.approach}</p>
            {cs.data.approachBullets && cs.data.approachBullets.length > 0 && (
              <ul>
                {cs.data.approachBullets.map(bullet => (
                  <li>{bullet}</li>
                ))}
              </ul>
            )}
          </div>
          <div class="modal-section">
            <h4>Outcomes</h4>
            <div class="modal-results">
              {cs.data.outcomes.map(outcome => (
                <div class="modal-result-item">
                  <strong>{outcome.value}</strong>
                  <span>{outcome.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}

  <script is:inline src="/assets/js/main.js"></script>
  <script is:inline>
    /* EmailJS setup */
    window.EMAILJS_PUBLIC_KEY   = 'qc2j8OCwQekmHwBUU';
    window.EMAILJS_SERVICE_ID   = 'service_oghv037';
    window.EMAILJS_TEMPLATE_ID  = 'template_jgd19bg';
    if (typeof emailjs !== 'undefined' && window.EMAILJS_PUBLIC_KEY !== 'YOUR_PUBLIC_KEY') {
      emailjs.init({ publicKey: window.EMAILJS_PUBLIC_KEY });
    }
  </script>

</Layout>
